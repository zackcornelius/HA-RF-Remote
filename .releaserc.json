{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/\"version\": \"[^\"]*\"/\"version\": \"${nextRelease.version}\"/' custom_components/rf_ceiling_fan/manifest.json && cd custom_components && zip -r ../rf_ceiling_fan-${nextRelease.version}.zip rf_ceiling_fan/"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "rf_ceiling_fan-*.zip",
            "label": "rf_ceiling_fan-${nextRelease.version}.zip"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "custom_components/rf_ceiling_fan/manifest.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
